%h1 Listing degrees

%table
  %thead
    %tr
      %th
      %th
      %th

  %tbody
    - @degrees.each do |degree|
      %tr
        %td= link_to 'Show', degree
        %td= link_to 'Edit', edit_degree_path(degree)
        %td= link_to 'Destroy', degree, method: :delete, data: { confirm: 'Are you sure?' }

%br

= link_to 'New Degree', new_degree_path
